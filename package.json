{
  "name": "midnight-wallet-kit",
  "version": "1.0.2",
  "description": "Production-grade wallet adapter system for the Midnight Network",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./react": {
      "types": "./dist/src/hooks/index.d.ts",
      "import": "./dist/src/hooks/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build && npm run test"
  },
  "keywords": [
    "midnight",
    "wallet",
    "adapter",
    "blockchain",
    "zk",
    "privacy"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "eventemitter3": "^5.0.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "react": "^18.2.0",
    "typescript": "^5.3.3",
    "vitest": "^3.1.1"
  },
  "peerDependencies": {
    "react": ">=17.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
